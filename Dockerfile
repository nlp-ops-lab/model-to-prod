# استفاده از پایتون ۳.۱۰ نسخه سبک به عنوان پایه
FROM python:3.10-slim

# تنظیم پوشه کاری داخل کانتینر داکر
WORKDIR /app

# کپی کردن فایل نیازمندی‌ها به داخل کانتینر
COPY requirements.txt .

# نصب کتابخانه‌های پایتون
# از کش استفاده نمی‌کنیم تا حجم ایمیج نهایی کم بماند
RUN pip install --no-cache-dir -r requirements.txt

# کپی کردن تمام فایل‌های پروژه به داخل پوشه کاری داکر
COPY . .

# دستوری که موقع اجرای کانتینر به صورت پیش‌فرض اجرا می‌شود
CMD ["bash"]